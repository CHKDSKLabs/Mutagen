            "format": "int32",
            "minimum": 0,
            "nullable": true,
            "type": "integer"
          },
          "slice_id": {
            "type": "string"
          }
        },
        "required": [
          "slice_id",
          "event",
          "at"
        ],
        "type": "object"
      },
      "StatusDto": {
        "properties": {
          "active_slice_id": {
            "description": "Slice currently held in `.mutagen/state/active-slice.json`, if any.",
            "nullable": true,
            "type": "string"
          },
          "active_stage": {
            "nullable": true,
            "type": "string"
          },
          "last_state_update_at": {
            "description": "Wall-clock of the last State Update record appended to the log (DSD-622).",
            "nullable": true,
            "type": "string"
          },
          "pipeline_mode": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "slice_counts": {
            "$ref": "#/components/schemas/SliceCountsDto"
          },
          "total_slices": {
