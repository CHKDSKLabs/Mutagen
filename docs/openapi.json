                ],
                "type": "string"
              },
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id",
              "envelope",
              "event"
            ],
            "type": "object"
          },
          {
            "description": "Answer accepted; echoed back so the GUI can clear its pending state\n(DDD §3.3 Domain Events `question.answered`).",
            "properties": {
              "answer_kind": {
                "type": "string"
              },
              "event": {
                "enum": [
                  "question_answered"
                ],
                "type": "string"
              },
              "question_id": {
                "type": "string"
              },
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id",
              "question_id",
              "answer_kind",
              "event"
            ],
            "type": "object"
          },
          {
            "description": "POL-S1: timeout fired before an Answer arrived.",
            "properties": {
              "event": {
                "enum": [
                  "question_timed_out"
                ],
                "type": "string"
              },
              "question_id": {
                "type": "string"
              },
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id",
              "question_id",
              "event"
            ],
            "type": "object"
          },
          {
            "description": "INV-S4 validation failure — kind mismatch or unknown question_id.",
            "properties": {
              "code": {
                "type": "string"
              },
              "event": {
                "enum": [
                  "error_validation"
                ],
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "question_id": {
                "nullable": true,
                "type": "string"
              },
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id",
              "code",
              "message",
              "event"
            ],
            "type": "object"
          },
          {
            "description": "L4-Session-003 placeholder — issued when a Workflow Command queues\n(POL-S4 first leg). Wired here so the taxonomy is complete in v1's\nOpenAPI schema and downstream GUI codegen sees it.",
            "properties": {
              "command": {
                "type": "string"
              },
              "event": {
                "enum": [
                  "command_accepted"
                ],
                "type": "string"
              },
              "request_id": {
                "type": "string"
              },
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id",
              "request_id",
              "command",
              "event"
            ],
            "type": "object"
          }
        ]
      },
      "SliceCountsDto": {
        "properties": {
