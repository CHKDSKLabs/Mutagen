{
  "$comment": "GENERATED — DO NOT EDIT. Run `cargo run -p xtask -- openapi` to regenerate.",
  "components": {
    "schemas": {
      "ClientMessage": {
        "description": "Client→server frame.",
        "discriminator": {
          "propertyName": "op"
        },
        "oneOf": [
          {
            "description": "Submit an Answer for an outstanding Question. Mismatched shape yields\n`error.validation` (INV-S4) — NOT a state transition.",
            "properties": {
              "answer": {},
              "op": {
                "enum": [
                  "submit_answer"
                ],
                "type": "string"
              },
              "question_id": {
                "type": "string"
              }
            },
            "required": [
              "question_id",
              "answer",
              "op"
            ],
            "type": "object"
          },
          {
            "description": "Test/dev hook so the harness can drive a question→answer round-trip\nend-to-end without a live April loop. Hidden behind the\n`cfg(any(test, feature = \"test-hooks\"))` switch on the server side;\nthe DTO stays here because the OpenAPI surface is one schema.",
            "properties": {
              "kind": {
                "type": "string"
              },
              "op": {
                "enum": [
                  "issue_question"
                ],
                "type": "string"
              },
              "payload": {
                "nullable": true
              },
              "prompt": {
                "type": "string"
              }
            },
            "required": [
              "prompt",
              "kind",
              "op"
            ],
            "type": "object"
          }
        ]
      },
      "CommandAcceptedDto": {
        "description": "202 body returned by every Workflow Command (DSD-322: silent success\nis forbidden — every accepted command echoes back a small envelope so\nthe caller has something to correlate against the WS broadcast).",
        "properties": {
          "accepted_at": {
            "description": "Wall-clock when the State Update record was appended (DSD-622).",
            "type": "string"
          },
          "command": {
            "description": "Stable command name: `dispatch_next` / `accept_review` / `escalate` /\n`finalize_slice` / `resume_slice`. Mirrors DDD §3.1 command names.",
            "type": "string"
          },
          "project_id": {
            "description": "Project this command targets.",
            "type": "string"
          },
          "request_id": {
            "description": "Request-id correlator (same UUIDv7 returned in `X-Request-Id`).",
            "type": "string"
          },
          "slice_id": {
            "description": "Slice this command targets. `None` for `dispatch_next` because the\nnext slice is chosen inside the lock and broadcast over the WS.",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "command",
          "project_id",
          "request_id",
          "accepted_at"
        ],
        "type": "object"
      },
      "ConfirmEscalateDto": {
        "description": "Response from POST /projects/{id}/slices/{slice_id}/confirm-escalate.",
        "properties": {
          "confirmation_token": {
            "type": "string"
          },
          "expires_at": {
            "description": "Wall-clock when the token expires (DSD-622). Five minutes from mint.",
            "type": "string"
          },
          "slice_id": {
            "type": "string"
          }
        },
        "required": [
          "confirmation_token",
          "slice_id",
          "expires_at"
        ],
        "type": "object"
      },
      "EmptyCommandBody": {
        "description": "Empty body shape accepted by accept / finalize / resume. Reserved for\nfuture optional notes; defining the type now keeps the OpenAPI surface\nstable as fields land.",
        "properties": {
          "note": {
            "description": "Optional operator note recorded with the State Update. Not used by\nthe v1 state machine — present so future audit work has a place\nwithout a wire-shape change.",
            "nullable": true,
            "type": "string"
          }
        },
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "code": {
            "description": "Stable SCREAMING_SNAKE_CASE machine string. Once shipped, never reused.",
            "type": "string"
          },
          "details": {
            "description": "Optional structured detail. Omitted on auth failures per INV-A4.",
            "nullable": true
          },
          "message": {
            "description": "Human-readable, lowercase, no trailing period.",
            "type": "string"
          },
          "request_id": {
            "description": "UUIDv7 request correlator echoed in the `X-Request-Id` header.",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "request_id"
        ],
        "type": "object"
      },
      "EscalateRequest": {
        "description": "Body shape for POST /projects/{id}/slices/{slice_id}/escalate. The\nconfirmation token is minted by `confirm-escalate` (DSD-330).",
        "properties": {
          "confirmation_token": {
            "description": "Token previously returned by `POST .../confirm-escalate` for this\nslice. Single-use, scoped to the slice it was minted against.",
            "type": "string"
          },
          "reason": {
            "description": "Optional human-readable rationale recorded on the State Update.",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "confirmation_token"
        ],
        "type": "object"
      },
      "HealthDto": {
        "properties": {
          "status": {
            "description": "`ok` | `degraded` | `down`. Stringly-typed on the wire by design —\ndownstream clients pattern-match, they don't enumerate.",
            "type": "string"
          },
          "version": {
            "description": "The same string `VersionDto::service_version` reports.",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ],
        "type": "object"
      },
      "OriginDto": {
        "properties": {
          "id": {
            "description": "`cli:<pid>` → \"<pid>\" as a string; `service:<session_id>` → session id.",
            "type": "string"
          },
          "kind": {
            "description": "`cli` | `service`.",
            "type": "string"
          }
        },
        "required": [
          "kind",
          "id"
        ],
        "type": "object"
      },
      "ProjectDto": {
        "properties": {
          "created_at": {
            "description": "RFC 3339 / ISO 8601 UTC timestamp (DSD-622).",
            "type": "string"
          },
          "name": {
            "description": "Operator-supplied display name. Free-form, non-empty.",
            "type": "string"
          },
          "project_id": {
            "description": "Stable UUIDv7 (DSD-623) assigned at registration. Sort-friendly.",
            "type": "string"
          },
          "root": {
            "description": "Canonical absolute path of the project root (ISC-008).",
            "type": "string"
          },
          "status": {
            "description": "Lifecycle: `registered` | `active` | `archived`.",
            "type": "string"
          }
        },
        "required": [
          "project_id",
          "name",
          "root",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "ProjectListDto": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProjectDto"
            },
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "QuestionEnvelopeDto": {
        "description": "FR-11 / ISC-009 wire shape. The `schema_version` field is **required** on\nthe OpenAPI side because the domain constructor stamps it unconditionally.",
        "properties": {
          "kind": {
            "description": "Question Kind discriminator: `free_text` | `multi_choice` |\n`multi_select` | `boolean` | `file_upload` (DDD §3.3 Value Objects).",
            "type": "string"
          },
          "payload": {
            "description": "Kind-specific payload (e.g. `options` for `multi_choice`). Absent for\n`free_text` and `boolean`. Schema-less by design — the discriminator\ndrives client rendering, not this field's shape.",
            "nullable": true
          },
          "prompt": {
            "type": "string"
          },
          "question_id": {
            "type": "string"
          },
          "schema_version": {
            "description": "Chat-protocol schema version. Always set by the server; clients pin\nto a known version range (DDD MD-5).",
            "type": "string"
          }
        },
        "required": [
          "schema_version",
          "question_id",
          "prompt",
          "kind"
        ],
        "type": "object"
      },
      "RegisterProjectRequest": {
        "properties": {
          "name": {
            "description": "Display name for the project. Trimmed; must be non-empty.",
            "type": "string"
          },
          "root": {
            "description": "Absolute filesystem path to the project workspace.",
            "type": "string"
          }
        },
        "required": [
          "root",
          "name"
        ],
        "type": "object"
      },
      "ServerMessage": {
        "description": "Server→client frame. All events carry a snake_case discriminator (DSD-621).",
        "discriminator": {
          "propertyName": "event"
        },
        "oneOf": [
          {
            "description": "April issued a Question Envelope. Echoes the full envelope including\n`schema_version` (ISC-009).",
            "properties": {
              "envelope": {
                "$ref": "#/components/schemas/QuestionEnvelopeDto"
              },
              "event": {
                "enum": [
