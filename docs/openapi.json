            "minimum": 0,
            "type": "integer"
          },
          "objective": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "target_loc": {
            "format": "int32",
            "minimum": 0,
            "type": "integer"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "layer",
          "bounded_context",
          "author_agent",
          "attempts",
          "target_loc",
          "objective"
        ],
        "type": "object"
      },
      "SliceQueueDto": {
        "properties": {
          "generated_at": {
            "type": "string"
          },
          "pipeline_mode": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "slices": {
            "items": {
              "$ref": "#/components/schemas/SliceDto"
            },
            "type": "array"
          }
        },
        "required": [
          "project_id",
          "pipeline_mode",
          "generated_at",
          "slices"
        ],
        "type": "object"
      },
      "StateLogPageDto": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/StateUpdateDto"
            },
            "type": "array"
          },
          "next_cursor": {
            "description": "Opaque cursor (DSD-625) — base64url of the next byte offset. Absent at tail.",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "StateUpdateDto": {
        "properties": {
          "at": {
            "type": "string"
          },
          "body": {
            "nullable": true
          },
          "event": {
            "type": "string"
          },
          "origin": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OriginDto"
              }
