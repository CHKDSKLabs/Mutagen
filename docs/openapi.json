          },
          "harness_version": {
            "description": "Harness library version linked into this service process.",
            "type": "string"
          },
          "service_version": {
            "description": "Service binary version (Cargo package version of `mutagen-service`).",
            "type": "string"
          }
        },
        "required": [
          "service_version",
          "harness_version",
          "chat_protocol_schema_version"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Mutagen workflow service. Spec is generated from handler annotations via utoipa per ADR-0002.",
    "license": {
      "name": ""
    },
    "title": "mutagen-service",
    "version": "0.3.3"
  },
  "openapi": "3.0.3",
  "paths": {
    "/projects": {
      "get": {
        "operationId": "list_projects",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListDto"
                }
              }
            },
            "description": "Registered projects (possibly empty)"
          }
        },
        "tags": [
          "projects"
        ]
      },
      "post": {
        "operationId": "register_project",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterProjectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDto"
                }
              }
            },
            "description": "Project registered"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Root already registered"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Validation failure"
          }
        },
        "tags": [
          "projects"
        ]
      }
    },
    "/projects/{project_id}": {
      "delete": {
        "operationId": "archive_project",
        "parameters": [
          {
            "description": "Project UUIDv7",
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Project archived (workspace files left intact)"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unknown project_id"
          }
        },
        "tags": [
          "projects"
        ]
      },
      "get": {
        "operationId": "get_project",
        "parameters": [
          {
            "description": "Project UUIDv7",
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDto"
                }
              }
            },
            "description": "Project detail"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unknown project_id"
          }
        },
        "tags": [
          "projects"
        ]
      }
    },
    "/projects/{project_id}/dispatch-next": {
      "post": {
        "operationId": "dispatch_next",
        "parameters": [
          {
            "description": "Project UUIDv7",
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandAcceptedDto"
                }
              }
            },
            "description": "Command accepted; completion broadcast on WS"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unknown project_id"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Project lock held by another writer"
          }
        },
        "tags": [
          "workflow"
        ]
      }
    },
    "/projects/{project_id}/session": {
      "get": {
        "operationId": "open_session",
        "parameters": [
          {
            "description": "Project UUIDv7.",
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "DSD-302: chat-protocol schema version. Omit for current. See harness/service/docs/websocket.md for wire shape.",
            "in": "query",
            "name": "schema_version",
            "required": false,
            "schema": {
              "nullable": true,
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientMessage"
              }
            }
          },
          "description": "Client→server WS text-frame shape (informational; HTTP GET carries no body).",
          "required": true
        },
        "responses": {
          "101": {
            "description": "WebSocket upgrade succeeded. See harness/service/docs/websocket.md for the chat-protocol frame schema (utoipa cannot fully express WS shape inline)."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unsupported schema_version."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Auth middleware rejected the upgrade handshake before the protocol switch."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Another session is already active on this project (ISC-015). Details carry `active_session_id`."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerMessage"
                }
              }
            },
            "description": "Server→client WS text-frame shape (informational; never emitted as an HTTP response)."
          }
        },
        "tags": [
          "session"
        ]
      }
    },
    "/projects/{project_id}/slices": {
      "get": {
        "operationId": "get_slices",
        "parameters": [
          {
            "description": "Project UUIDv7",
